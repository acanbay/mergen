# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Local test file (root directory only)
/test.py

# Ruff / mypy caches
.ruff_cache/
.mypy_cache/

# Jupyter
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/
ENV/

# VS Code — keep shared settings, exclude personal state
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# OS files
.DS_Store
Thumbs.db

# Mergen output artefacts
*.csv
*.xlsx
*.pdf
*.png
!docs/**/*.png
!examples/**/*.png

# Mergen runtime output directory
outputs/
